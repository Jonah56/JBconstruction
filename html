<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>JB Construction</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }

    header {
      display: flex;
      justify-content: space-between;
      padding: 20px;
      background: #111;
      color: white;
    }

    nav a {
      color: white;
      margin: 0 10px;
      text-decoration: none;
    }

    .hero {
      height: 90vh;
      background: url('https://images.unsplash.com/photo-1503387762-592deb58ef4e') center/cover;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      text-align: center;
    }

    .hero-text {
      background: rgba(0,0,0,0.6);
      padding: 30px;
    }

    .section {
      padding: 60px 20px;
      text-align: center;
    }

    .dark {
      background: #222;
      color: white;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
      gap: 20px;
    }

    .card {
      background: #ff6600;
      padding: 20px;
      color: white;
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
      gap: 10px;
    }

    .gallery img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    form {
      max-width: 500px;
      margin: auto;
    }

    input, textarea {
      width: 100%;
      padding: 10px;
      margin: 10px 0;
    }

    button {
      background: #ff6600;
      color: white;
      padding: 10px;
      border: none;
      width: 100%;
    }

    .btn {
      background: #ff6600;
      padding: 10px 20px;
      color: white;
      text-decoration: none;
      display: inline-block;
      margin-top: 10px;
    }
  </style>
</head>

<body>

<header>
  <div class="logo">JB Construction</div>
  <nav>
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#gallery">Gallery</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section class="hero">
  <div class="hero-text">
    <h1>From Foundation to Finish</h1>
    <p>Residential Construction Done Right</p>
    <a href="#contact" class="btn">Get a Free Quote</a>
  </div>
</section>

<section id="about" class="section">
  <h2>About JB Construction</h2>
  <p>
    JB Construction specializes in full residential builds, remodels, and everything in between.
    We take pride in delivering quality craftsmanship and reliable results.
  </p>
</section>

<section id="services" class="section dark">
  <h2>Our Services</h2>
  <div class="grid">
    <div class="card">New Home Construction</div>
    <div class="card">Remodeling</div>
    <div class="card">Framing</div>
    <div class="card">Roofing</div>
    <div class="card">Concrete</div>
    <div class="card">General Contracting</div>
  </div>
</section>

<section id="gallery" class="section">
  <h2>Our Work</h2>
  <div class="gallery">
    <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e">
    <img src="https://images.unsplash.com/photo-1502005229762-cf1b2da7c5d6">
    <img src="https://images.unsplash.com/photo-1501183638710-841dd1904471">
    <img src="https://images.unsplash.com/photo-1497366216548-37526070297c">
  </div>
</section>

<section id="contact" class="section dark">
  <h2>Request a Quote</h2>

  <form>
    <input type="text" placeholder="Name" required>
    <input type="email" placeholder="Email" required>
    <input type="text" placeholder="Phone">
    <textarea placeholder="Tell us about your project..." required></textarea>
    <button type="submit">Send Request</button>
  </form>

</section>

<footer>
  <p>© 2026 JB Construction</p>
</footer>

</body>
</html>
